<h2 class="form-title" style="color: #751F1F;">Log in</h2>

<div class="form-container" style="max-width: 400px; margin: 0 auto; background: #FAEDCD; border-radius: 1.5rem; padding: 2rem; box-shadow: 0 2px 12px rgba(117,31,31,0.07);">
  <%= simple_form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
    <div class="form-inputs">
      <div>
        <%= f.input :email,
                    required: true,
                    autofocus: true,
                    input_html: { autocomplete: "email", style: "border-radius: 1.5rem; background: #F4F4F4;" },
                    label: "Email Address" %>
      </div>

      <div>
        <%= f.input :password,
                    required: true,
                    input_html: { autocomplete: "current-password", style: "border-radius: 1.5rem; background: #F4F4F4;" },
                    label: "Password" %>
      </div>

      <% if devise_mapping.rememberable? %>
        <div>
          <%= f.input :remember_me, as: :boolean, label: "Remember me" %>
        </div>
      <% end %>
    </div>

    <div class="form-actions" style="margin-top: 1.5rem;">
      <%= f.button :submit, "Log in", class: "btn-burgandy" %>
    </div>
  <% end %>

  <div class="form-links" style="margin-top: 1.5rem; text-align: center;">
    <%= render "devise/shared/links" %>
  </div>
</div>
